---
import Site from '../../layouts/Site.astro';
import { loadProducts, getProduct } from '../../lib/products.ts';

export async function getStaticPaths() {
  const products = await loadProducts();
  return products.map((p) => ({ params: { sku: p.sku } }));
}

const { sku } = Astro.params;
const product = await getProduct(sku!);
if (!product) {
  return Astro.redirect('/');
}
---
<Site title={product.name}>
  <a href="/" style="font-size:13px;">← Back to catalog</a>
  <div style="font-family:ui-monospace,monospace;color:var(--muted);font-size:12px;margin-top:24px;">{product.sku}</div>
  <h1 style="margin:6px 0 8px;">{product.name}</h1>
  <p style="color:var(--muted);font-size:16px;margin:0 0 24px;">{product.summary}</p>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:32px;align-items:start;">
    <article
      style="background:var(--card);border:1px solid var(--line);border-radius:8px;padding:24px;white-space:pre-wrap;font-family:system-ui;"
    >
      {product.description}
    </article>
    <aside style="background:var(--card);border:1px solid var(--line);border-radius:8px;padding:16px;font-size:13px;">
      <strong style="display:block;margin-bottom:8px;">Specs</strong>
      <pre style="margin:0;font-family:ui-monospace,monospace;font-size:12px;color:var(--muted);white-space:pre-wrap;">{JSON.stringify(product.specs, null, 2)}</pre>
      {product.related.length > 0 && (
        <>
          <strong style="display:block;margin:16px 0 8px;">Also of interest</strong>
          <ul style="list-style:none;padding:0;margin:0;">
            {product.related.map((r) => (
              <li>
                <a href={`/p/${r}/`} style="font-family:ui-monospace,monospace;font-size:12px;">{r}</a>
              </li>
            ))}
          </ul>
        </>
      )}
      <strong style="display:block;margin:16px 0 8px;">ACT</strong>
      <a href={`/act/nodes/${product.sku}.json`} style="font-family:ui-monospace,monospace;font-size:12px;">/act/nodes/{product.sku}.json</a>
    </aside>
  </div>
</Site>
