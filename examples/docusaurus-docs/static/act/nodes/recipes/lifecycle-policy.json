  "type": "reference",
  "title": "Bucket lifecycle policy reference",
  "summary": "Lifecycle rules table for retention configuration.",
  "summary_source": "author",
  "content": [
    {
      "type": "prose",
      "format": "markdown",
      "text": "The supported lifecycle transitions:"
    },
    {
      "type": "data",
      "format": "json",
      "text": "{\n  \"transitions\": [\n    { \"from\": \"STANDARD\", \"to\": \"INFREQUENT\", \"after_days\": 30 },\n    { \"from\": \"INFREQUENT\", \"to\": \"ARCHIVE\",   \"after_days\": 90 },\n    { \"from\": \"ARCHIVE\",   \"to\": \"DEEP\",       \"after_days\": 365 }\n  ]\n}"
    },
    {
      "type": "prose",
      "format": "markdown",
      "text": "Apply the policy with PUT /v1/buckets/{bucket}/lifecycle."
    }
  ],
