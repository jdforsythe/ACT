    {
      "act_version": "0.1",
      "id": "api/buckets/create",
      "type": "reference",
      "title": "Create a bucket",
      "summary": "Provision a new storage bucket in the workspace.",
      "summary_source": "author",
      "content": [
        {
          "type": "prose",
          "format": "markdown",
          "text": "Request"
        },
        {
          "type": "code",
          "language": "bash",
          "text": "curl -X POST -H 'Authorization: Bearer $TOKEN' \\\n  -d '{\"name\":\"my-bucket\",\"region\":\"us-east-1\"}' \\\n  https://api.tinybox.dev/v1/buckets"
        },
        {
          "type": "prose",
          "format": "markdown",
          "text": "Response"
        },
        {
          "type": "prose",
          "format": "markdown",
          "text": "The API returns the created bucket descriptor. See List buckets."
        }
      ],
      "tokens": {
        "summary": 8,
        "body": 28
      },
      "metadata": {
