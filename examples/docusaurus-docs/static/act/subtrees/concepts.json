    },
    {
      "act_version": "0.1",
      "id": "concepts/storage/lifecycle",
      "type": "doc",
      "title": "Lifecycle policies",
      "summary": "Automatic transitions between storage classes by age or tag.",
      "summary_source": "author",
      "content": [
        {
          "type": "prose",
          "format": "markdown",
          "text": "Lifecycle policies move objects between storage classes (STANDARD,\nINFREQUENT, ARCHIVE, DEEP) based on age or tag predicates."
        }
      ],
