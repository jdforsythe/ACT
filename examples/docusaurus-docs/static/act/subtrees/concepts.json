    {
      "act_version": "0.1",
      "id": "concepts/auth",
      "type": "doc",
      "title": "Authentication",
      "summary": "Bearer-token authentication and per-project scoping.",
      "summary_source": "author",
      "content": [
        {
          "type": "prose",
          "format": "markdown",
          "text": "Authenticate via a bearer token in the Authorization header.\nTokens are issued from the dashboard and scoped per project."
        }
      ],
      "tokens": {
        "summary": 5,
