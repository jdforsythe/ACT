    {
      "act_version": "0.1",
      "id": "concepts/data-model",
      "type": "doc",
      "title": "Data model",
      "summary": "Buckets, Objects, and Webhooks: the three top-level resources.",
      "summary_source": "author",
      "content": [
        {
          "type": "prose",
          "format": "markdown",
          "text": "Tinybox exposes three nouns: Buckets (containers), Objects\n(blobs), and Webhooks (lifecycle event delivery). Buckets nest objects;\nwebhooks subscribe to events on either."
        }
      ],
      "tokens": {
        "summary": 8,
        "body": 22
      },
      "metadata": {
        "source": {
