{
  "name": "@act-spec/remix-static",
  "version": "0.0.0",
  "description": "PRD-406 Remix-Vite static-export generator for the ACT (Agent Content Tree) v0.1 reference implementation.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/act-spec/act.git",
    "directory": "packages/remix-static"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "conformance": "tsx conformance.ts"
  },
  "peerDependencies": {
    "@remix-run/dev": "^2.0.0",
    "react": ">=18 <20",
    "react-dom": ">=18 <20",
    "vite": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@remix-run/dev": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@act-spec/adapter-framework": "workspace:*",
    "@act-spec/component-react": "workspace:*",
    "@act-spec/core": "workspace:*",
    "@act-spec/generator-core": "workspace:*",
    "@act-spec/markdown-adapter": "workspace:*",
    "@act-spec/validator": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
