{
  "name": "@act-spec/cli",
  "version": "0.0.0",
  "description": "PRD-409 standalone CLI for the ACT (Agent Content Tree) v0.1 reference implementation. Framework-free generator orchestration: loads act.config.{ts,mts,mjs,cjs,js,json}, instantiates adapters + the PRD-400 pipeline (via @act-spec/generator-core), and writes the static file set per PRD-105.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "act": "./bin/act.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "bin"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/act-spec/act.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "conformance": "tsx conformance.ts"
  },
  "dependencies": {
    "@act-spec/adapter-framework": "workspace:*",
    "@act-spec/core": "workspace:*",
    "@act-spec/generator-core": "workspace:*",
    "@act-spec/markdown-adapter": "workspace:*",
    "@act-spec/programmatic-adapter": "workspace:*",
    "@act-spec/validator": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
