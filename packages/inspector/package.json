{
  "name": "@act-spec/inspector",
  "version": "0.0.0",
  "description": "PRD-601 inspector CLI + library for the ACT (Agent Content Tree) v0.1 wire format. Subcommands: fetch, walk, diff, token-budget. Reuses @act-spec/validator for parsing and structural checks (PRD-601-R1).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "act-inspect": "./bin/act-inspect.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "bin"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/act-spec/act.git",
    "directory": "packages/inspector"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "conformance": "tsx conformance.ts"
  },
  "dependencies": {
    "@act-spec/core": "workspace:*",
    "@act-spec/validator": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
