{
  "name": "@act-spec/nuxt",
  "version": "0.0.0",
  "description": "PRD-407 Nuxt module for the ACT (Agent Content Tree) v0.1 reference implementation. Wraps the PRD-400 generator pipeline against Nuxt 3+ static export (`nuxt generate`).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/act-spec/act.git",
    "directory": "packages/nuxt"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "conformance": "tsx conformance.ts"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0 <5.0.0",
    "@nuxt/kit": ">=3.0.0 <5.0.0",
    "vue": ">=3.4 <4"
  },
  "peerDependenciesMeta": {
    "nuxt": {
      "optional": true
    },
    "@nuxt/kit": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@act-spec/adapter-framework": "workspace:*",
    "@act-spec/component-vue": "workspace:*",
    "@act-spec/core": "workspace:*",
    "@act-spec/generator-core": "workspace:*",
    "@act-spec/markdown-adapter": "workspace:*",
    "@act-spec/validator": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
