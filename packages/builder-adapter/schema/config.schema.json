{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://act-spec.org/schemas/206/config.schema.json",
  "title": "act-builderio adapter config",
  "description": "PRD-206-R2 — config schema for @act-spec/builder-adapter.",
  "type": "object",
  "required": ["apiKey", "models"],
  "additionalProperties": false,
  "properties": {
    "apiKey": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["from_env"],
          "additionalProperties": false,
          "properties": { "from_env": { "type": "string", "minLength": 1 } }
        }
      ]
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "mode": { "type": "string", "enum": ["pass-through", "extraction"] },
    "version": { "type": "string", "enum": ["published", "draft"] },
    "query": { "type": "object", "additionalProperties": true },
    "typeMapping": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "fieldMapping": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "abstract": { "type": "string", "minLength": 1 },
        "body": { "type": "string", "minLength": 1 },
        "tags": { "type": "string", "minLength": 1 },
        "related": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    },
    "idField": { "type": "string", "minLength": 1 },
    "referenceDepth": { "type": "integer", "minimum": 0, "maximum": 3 },
    "componentMapping": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "fields"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string", "pattern": "^marketing:" },
          "fields": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "symbolRecursionMax": { "type": "integer", "minimum": 1, "maximum": 3 },
    "locale": {
      "type": "object",
      "required": ["locales", "defaultLocale"],
      "additionalProperties": false,
      "properties": {
        "locales": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "defaultLocale": { "type": "string", "minLength": 1 }
      }
    },
    "experiments": { "type": "string", "enum": ["skip", "emit"] },
    "webhookSecret": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": { "type": "string", "enum": ["field", "extract", "needs-llm"] }
      }
    },
    "concurrency": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "transform": { "type": "integer", "minimum": 1, "maximum": 16 }
      }
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9._\\-]|/)*[a-z0-9]$"
    },
    "allowEmpty": { "type": "boolean" },
    "unmappedComponentWarningThreshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "debugLogging": { "type": "boolean" }
  }
}
