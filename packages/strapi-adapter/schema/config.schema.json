{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://act-spec.org/schemas/205/config.schema.json",
  "title": "act-strapi adapter config",
  "description": "PRD-205-R2 — config schema for @act-spec/strapi-adapter.",
  "type": "object",
  "required": ["baseUrl", "apiToken", "contentTypes"],
  "additionalProperties": false,
  "properties": {
    "baseUrl": {
      "type": "string",
      "minLength": 1,
      "pattern": "^https?://"
    },
    "apiToken": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["from_env"],
          "additionalProperties": false,
          "properties": { "from_env": { "type": "string", "minLength": 1 } }
        }
      ]
    },
    "contentTypes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "strapiVersion": { "type": "string", "enum": ["v4", "v5"] },
    "transport": { "type": "string", "enum": ["rest", "graphql"] },
    "graphqlEndpoint": { "type": "string", "minLength": 1 },
    "graphqlQuery": { "type": "string", "minLength": 1 },
    "typeMapping": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "fieldMapping": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "abstract": { "type": "string", "minLength": 1 },
        "body": { "type": "string", "minLength": 1 },
        "tags": { "type": "string", "minLength": 1 },
        "related": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    },
    "idField": { "type": "string", "minLength": 1 },
    "parseMarkdown": { "type": "boolean" },
    "populateDepth": { "type": "integer", "minimum": 0, "maximum": 4 },
    "componentMapping": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "fields"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string", "pattern": "^marketing:" },
          "fields": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "dynamicZoneMax": { "type": "integer", "minimum": 1, "maximum": 3 },
    "locale": {
      "type": "object",
      "required": ["locales", "defaultLocale"],
      "additionalProperties": false,
      "properties": {
        "locales": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "defaultLocale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": { "type": "string", "enum": ["field", "extract", "needs-llm"] }
      }
    },
    "concurrency": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "transform": { "type": "integer", "minimum": 1, "maximum": 16 }
      }
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9._\\-]|/)*[a-z0-9]$"
    },
    "webhookSecret": { "type": "string", "minLength": 1 },
    "allowEmpty": { "type": "boolean" },
    "debugLogging": { "type": "boolean" }
  }
}
