{
  "name": "@act-spec/core",
  "version": "0.0.0",
  "description": "Shared TypeScript types and reporter contracts for the ACT v0.1 reference implementation. Types are derived from schemas/ via codegen.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./conformance-reporter": {
      "types": "./dist/conformance-reporter.d.ts",
      "import": "./dist/conformance-reporter.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/act-spec/act.git",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "codegen": "tsx scripts/codegen.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run stryker.config.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "conformance": "node -e \"console.log('no conformance gate yet for @act-spec/core')\""
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "^2.1.9",
    "json-schema-to-typescript": "^15.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
