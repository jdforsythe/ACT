{
  "name": "@act-spec/generator-core",
  "version": "0.0.0",
  "description": "PRD-400 generator framework for the ACT (Agent Content Tree) v0.1 reference implementation. Pipeline, envelope builders, and capability/pinning helpers — shared by every first-party generator.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/act-spec/act.git",
    "directory": "packages/generator-core"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "conformance": "node -e \"console.log('no conformance gate for @act-spec/generator-core (framework-only; PRD-400 is exercised by leaf generator conformance gates)')\""
  },
  "dependencies": {
    "@act-spec/adapter-framework": "workspace:*",
    "@act-spec/core": "workspace:*",
    "@act-spec/validator": "workspace:*"
  },
  "devDependencies": {
    "@act-spec/adapter-markdown": "workspace:*",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
