{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "vite.config.ts", "vitest.config.ts", "conformance.ts"],
  "exclude": ["dist", "node_modules"]
}
