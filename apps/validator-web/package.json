{
  "name": "@act-spec/validator-web",
  "version": "0.0.0",
  "private": true,
  "description": "Hosted client-side ACT validator SPA (PRD-600 / Q8). Wraps @act-spec/validator for browser consumption; deploys to GitHub Pages at /validator/.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "conformance": "tsx conformance.ts"
  },
  "dependencies": {
    "@act-spec/core": "workspace:*",
    "@act-spec/validator": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
